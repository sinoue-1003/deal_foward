# deal_foward 環境変数
# このファイルを .env にコピーして値を設定してください
# ※ .env を Git にコミットしないでください

# =============================================================================
# コア設定
# =============================================================================

# Supabase データベース接続URL
# Settings → Database → Connection string (URI) から取得
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Claude API キー
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API キー (Whisper 文字起こし用)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# AIエージェント認証キー
# エージェントが X-Agent-Api-Key ヘッダーに設定して /api/agent/* にアクセスします
# 推奨: openssl rand -hex 32 で生成
AGENT_API_KEY=your-secret-agent-api-key

# AIエージェントへの通知Webhook URL (任意)
# Make, n8n, カスタムAPIなど
AGENT_WEBHOOK_URL=https://your-agent-webhook.com/webhook

# =============================================================================
# 外部API連携 (OAuth 2.0)
# コールバックURL: http://localhost:8000/api/oauth/callback
# =============================================================================

# --- Slack ---
# アプリ作成: https://api.slack.com/apps → Create New App → OAuth & Permissions
# Redirect URL に http://localhost:8000/api/oauth/callback を追加
# 必要スコープ: chat:write, channels:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Microsoft Teams (Azure AD) ---
# アプリ登録: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI に http://localhost:8000/api/oauth/callback を追加
# 必要権限: Chat.ReadWrite (Microsoft Graph)
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# --- Zoom ---
# アプリ作成: https://marketplace.zoom.us/develop/create → OAuth
# Redirect URL に http://localhost:8000/api/oauth/callback を追加
# 必要スコープ: meeting:read, meeting:write
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Google (Meet + Gmail 共通) ---
# プロジェクト作成: https://console.cloud.google.com → APIs & Services → Credentials
# OAuth 2.0 クライアントID を作成し Redirect URI に http://localhost:8000/api/oauth/callback を追加
# 有効にするAPI: Google Calendar API, Gmail API
# ※ Google Meet と Gmail は同じ Client ID / Secret を共有します
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Salesforce ---
# 接続アプリ作成: Salesforce Setup → Apps → App Manager → New Connected App
# Callback URL に http://localhost:8000/api/oauth/callback を追加
# 必要スコープ: api, refresh_token
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- HubSpot ---
# アプリ作成: https://developers.hubspot.com → Apps → Create app → Auth
# Redirect URL に http://localhost:8000/api/oauth/callback を追加
# 必要スコープ: contacts, crm.objects.deals.read
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
