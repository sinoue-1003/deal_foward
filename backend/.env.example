# deal_foward バックエンド環境変数
# このファイルを backend/.env にコピーして値を設定してください
# ※ .env をGitにコミットしないでください

# Supabase データベース接続URL
# Settings → Database → Connection string (URI) から取得
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Claude API キー
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API キー (Whisper 文字起こし用)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# AIエージェント認証キー (任意の文字列、推奨: 64文字以上のランダム文字列)
# エージェントが X-Agent-Api-Key ヘッダーに設定して使用します
AGENT_API_KEY=your-secret-agent-api-key

# AIエージェントへの通知Webhook URL (任意)
# Make, n8n, カスタムAPIなど
AGENT_WEBHOOK_URL=https://your-agent-webhook.com/webhook
